datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

enum UserType {
  driver
  owner
  admin
}

enum AdminRole {
  super_admin
  ops_staff
}

enum UserStatus {
  active
  banned
}

enum OwnerType {
  home
  society
  commercial
  govt
  municipality
}

enum VehicleType {
  bike
  car
  commercial
}

enum ParkingType {
  home
  society
  commercial
  govt
  municipality
}

enum ParkingStatus {
  active
  paused
  banned
}

enum BookingStatus {
  confirmed
  active
  completed
  cancelled
}

enum WalletTxnType {
  credit
  debit
  refund
  overstay_charge
  payout
}

enum PayoutStatus {
  pending
  processing
  transferred
  failed
}

enum DisputeStatus {
  open
  reviewing
  resolved
}

enum DisputeResolution {
  full_refund
  partial_refund
  no_refund
  owner_penalty
}

enum AddonType {
  car_wash
  ev_charging
  tyre_inflation
}

enum AddonStatus {
  pending
  in_progress
  completed
}

enum ReviewTargetType {
  parking
  addon
}

enum SubscriptionPlan {
  basic
  premium
  pro
}

enum SubscriptionStatus {
  active
  cancelled
  expired
}

model User {
  id             String         @id @default(uuid())
  phone          String?        @unique
  email          String?        @unique
  passwordHash   String?        @map("password_hash")
  name           String?
  userType       UserType       @map("user_type")
  adminRole      AdminRole?     @map("admin_role")
  walletBalance  Decimal        @default(0.0) @map("wallet_balance")
  status         UserStatus     @default(active)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  // Relationships
  ownerProfile      OwnerProfile?
  vehicles          Vehicle[]
  parkings          Parking[]
  bookings          Booking[]
  walletTxns        WalletTxn[]
  payouts           Payout[]
  raisedDisputes    Dispute[]
  reviews           Review[]
  subscriptions     Subscription[]

  @@map("users")
}

model OwnerProfile {
  id                String    @id @default(uuid())
  userId            String    @unique @map("user_id")
  ownerType         OwnerType @map("owner_type")
  bankAccount       String?   @map("bank_account") // AES-256 encrypted
  bankIfsc          String?   @map("bank_ifsc")    // AES-256 encrypted
  accountHolderName String?   @map("account_holder_name")
  gstNumber          String?   @map("gst_number")
  aadharNumber       String?   @map("aadhar_number")
  panNumber          String?   @map("pan_number")
  verificationStatus String    @default("pending") @map("verification_status")
  strikeCount        Int       @default(0) @map("strike_count")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("owner_profiles")
}

model Vehicle {
  id          String      @id @default(uuid())
  userId      String      @map("user_id")
  vehicleType VehicleType @map("vehicle_type")
  regNumber   String      @map("reg_number")
  isActive    Boolean     @default(false) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("vehicles")
}

model Parking {
  id            String        @id @default(uuid())
  ownerId       String        @map("owner_id")
  name          String
  parkingType   ParkingType   @map("parking_type")
  address       String
  latitude      Float
  longitude     Float
  location      Unsupported("geography(Point, 4326)")?
  photos        String[]
  openTime      String        @map("open_time") // HH:mm format
  closeTime     String        @map("close_time") // HH:mm format
  is24hr        Boolean       @default(false) @map("is_24hr")
  status        ParkingStatus @default(active)
  avgRating     Decimal       @default(0.0) @map("avg_rating")
  addonsEnabled String[]      @map("addons_enabled")
  isFull        Boolean       @default(false) @map("is_full")
  isClosed      Boolean       @default(false) @map("is_closed")
  reopenAt      DateTime?     @map("reopen_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  user          User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  slots         ParkingSlot[]
  pricingRules  PricingRule[]
  bookings      Booking[]
  customAddons  CustomAddon[]

  @@index([location], type: Gist)
  @@map("parkings")
}

model ParkingSlot {
  id             String      @id @default(uuid())
  parkingId      String      @map("parking_id")
  vehicleType    VehicleType @map("vehicle_type")
  totalSlots     Int         @map("total_slots")
  availableSlots Int         @map("available_slots")

  parking Parking @relation(fields: [parkingId], references: [id], onDelete: Cascade)

  @@unique([parkingId, vehicleType])
  @@map("parking_slots")
}

model PricingRule {
  id           String      @id @default(uuid())
  parkingId    String      @map("parking_id")
  vehicleType  VehicleType @map("vehicle_type")
  weekdayPrice Decimal     @map("weekday_price")
  weekendPrice Decimal     @map("weekend_price")
  peakRules    Json?       @map("peak_rules")

  parking Parking @relation(fields: [parkingId], references: [id], onDelete: Cascade)

  @@unique([parkingId, vehicleType])
  @@map("pricing_rules")
}

model Booking {
  id             String        @id @default(uuid())
  userId         String        @map("user_id")
  parkingId      String        @map("parking_id")
  vehicleType    VehicleType   @map("vehicle_type")
  startTime      DateTime      @map("start_time")
  endTime        DateTime      @map("end_time")
  actualEnd      DateTime?     @map("actual_end")
  grossAmount    Decimal       @map("gross_amount")
  commission     Decimal
  ownerShare     Decimal       @map("owner_share")
  overstayAmount Decimal       @default(0.0) @map("overstay_amount")
  totalCharged   Decimal       @map("total_charged")
  status         BookingStatus
  checkinAt      DateTime?     @map("checkin_at")
  checkoutAt     DateTime?     @map("checkout_at")
  qrToken        String        @unique @map("qr_token")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  parking       Parking        @relation(fields: [parkingId], references: [id], onDelete: Cascade)

  disputes      Dispute[]
  addonBookings AddonBooking[]
  reviews       Review[]

  @@map("bookings")
}

model WalletTxn {
  id            String        @id @default(uuid())
  userId        String        @map("user_id")
  type          WalletTxnType
  amount        Decimal
  referenceId   String?       @map("reference_id")
  referenceType String?       @map("reference_type")
  description   String
  balanceAfter  Decimal       @map("balance_after")
  createdAt     DateTime      @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallet_txns")
}

model Payout {
  id           String       @id @default(uuid())
  ownerId      String       @map("owner_id")
  weekStart    DateTime     @map("week_start") @db.Date
  weekEnd      DateTime     @map("week_end") @db.Date
  grossAmount  Decimal      @map("gross_amount")
  commission   Decimal
  netAmount    Decimal      @map("net_amount")
  disputeHold  Decimal      @default(0.0) @map("dispute_hold")
  finalPayout  Decimal      @map("final_payout")
  status       PayoutStatus @default(pending)
  utrNumber    String?      @map("utr_number")
  processedAt  DateTime?    @map("processed_at")
  createdAt    DateTime     @default(now()) @map("created_at")

  user User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@map("payouts")
}

model Dispute {
  id           String             @id @default(uuid())
  bookingId    String             @map("booking_id")
  raisedById   String             @map("raised_by_id")
  raisedByType UserType           @map("raised_by_type")
  reason       String
  description  String
  status       DisputeStatus      @default(open)
  resolution   DisputeResolution?
  refundAmount Decimal?           @map("refund_amount")
  adminNote    String?            @map("admin_note")
  createdAt    DateTime           @default(now()) @map("created_at")
  resolvedAt   DateTime?          @map("resolved_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  raisedBy User   @relation(fields: [raisedById], references: [id], onDelete: Cascade)

  @@map("disputes")
}

model SystemSetting {
  key         String   @id
  value       Json
  description String?
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model CustomAddon {
  id          String   @id @default(uuid())
  parkingId   String   @map("parking_id")
  name        String
  description String?
  price       Decimal
  image       String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  parking  Parking        @relation(fields: [parkingId], references: [id], onDelete: Cascade)
  bookings AddonBooking[]

  @@map("custom_addons")
}

model AddonBooking {
  id            String       @id @default(uuid())
  bookingId     String       @map("booking_id")
  customAddonId String?      @map("custom_addon_id")
  addonName     String       @map("addon_name")
  serviceLevel  String?      @map("service_level")
  amount        Decimal
  commission    Decimal
  ownerShare    Decimal      @map("owner_share")
  status        AddonStatus  @default(pending)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  booking     Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  customAddon CustomAddon? @relation(fields: [customAddonId], references: [id], onDelete: SetNull)

  @@map("addon_bookings")
}

model Review {
  id           String           @id @default(uuid())
  bookingId    String           @map("booking_id")
  reviewerId   String           @map("reviewer_id")
  targetId     String           @map("target_id")
  targetType   ReviewTargetType @map("target_type")
  rating       Int
  comment      String?
  createdAt    DateTime         @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  reviewer User   @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model Subscription {
  id        String             @id @default(uuid())
  userId    String             @map("user_id")
  plan      SubscriptionPlan   @default(basic)
  status    SubscriptionStatus @default(active)
  startDate DateTime           @default(now()) @map("start_date")
  endDate   DateTime           @map("end_date")
  price     Decimal            @default(0.0)
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}
